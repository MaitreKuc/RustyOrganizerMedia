# RustMediaCenter Configuration

# Path to the rclone mount (source)
RCLONE_MOUNT_PATH=/mnt/remote/torbox

# Path to the organized output directory
OUTPUT_PATH=/mnt/RustMediaCenter

# TMDb API key (required) https://www.themoviedb.org/settings/api
TMDB_API_KEY=<API KEY>

# TVDB API key (required)
TVDB_API_KEY=<API KEY>

# Scan interval in seconds (0 = run once)
SCAN_INTERVAL=300

# SQLite cache database path
CACHE_DB_PATH=/mnt/RustMediaCenter/.rustmediacenter-cache.db

# Log level (trace, debug, info, warn, error)
LOG_LEVEL=info

# Remove old symbolic links that no longer point to valid files
REMOVE_OLD_LINKS=true